{
  name: "UI: main_text_button",
  id: "main_text_button",
  size: "0,0",
  center: "0, 0",
  pos: "100, 100",
  component: [
    "FitChildren()",
    {
      name: "LabelButton",
      properties: {
        back_label: "back_label",
        hover_label: "hover_label",
      },
    },
  ],
  values: {
    text: "文本按钮",
    style_normal: {
      font: "bold 18px Arial",
      fill_style: "#5A73D6",
    },
    style_hover: {
      font: "bold 18px Arial",
      fill_style: "white",
      underline_color: "white",
      underline_width: 2,
    },
    style_disabled: {
      font: "bold 18px Arial",
      fill_style: "gray",
      underline_color: "gray",
      underline_width: 2,
    },
  },
  items: [
    {
      center: "0.5,0.5",
      i18n: "$val:text",
      style: "$val:style_normal",
      component: [{ name: "Label", id: "back_label" }],
    },
    {
      center: "0.5,0.5",
      i18n: "$val:text",
      style: "$val:style_hover",
      component: [{ name: "Label", id: "hover_label" }],
    },
  ],
}
