{
  id: "gogogo_loop",
  name: "gogogo_loop",
  visible: false,
  opacity: 0,
  i18n: "Go! ➡",
  outlineColor: "#005A8E",
  outlineWidth: 5,
  outlineAlpha: 1,
  style: {
    fill_style: "white",
    font: "46px \"Arial Black\", Arial",
  },
  component: [
    {
      id: "play_gogogo_loop",
      cls: "ComponentsPlayer",
      enabled: false,
      properties: {
        components: [ "sounds", "opacity_flash" ],
        local: true,
        recursive: true,
      },
    },
    {
      id: "sounds",
      cls: "Sounds",
      enabled: false,
      args: [ "350", "ok", "800", "ok", "800", "ok" ],
    },
    {
      id: "opacity_flash",
      cls: "OpacityFlash",
      enabled: false,
      properties: {
        times: -1,
        steps: [ 0, 350, 1, 100, 1, 350, 0 ],
      },
    },
    {
      cls: "Alignment",
      properties: {
        right: "right",
        top: "top",
        offset: { t: 33, r: -10 },
        once: true,
      },
    },
  ],
}
