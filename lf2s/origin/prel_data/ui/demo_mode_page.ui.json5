{
  name: "页面：DEMO模式",
  id: "demo_mode_page",
  component: [
    {
      name: "DemoModeLogic",
      properties: {
        focus_prefix: "focus_prefix",
        focus_on: "focus_on",
        cam_ctrl: "cam_ctrl",
        score_board: "score_board",
      },
    },
    {
      id: "cam_ctrl",
      name: "CameraCtrl",
      properties: { },
    },
  ],
  items: [
    {
      pos: "0,0,5",
      visible: false,
      template: "ui/player_keys_hints.ui.json5",
    },
    "ui/center_pause_label.ui.json5",
    "ui/fighter_stat_s_x8.ui.json5",
    {
      visible: true,
      component: [ { name: "PauseHandling", properties: { reverse: true } } ],
      i18n: "DEMO",
      outlineColor: "#005A8E",
      outlineWidth: 4,
      outlineAlpha: 1,
      style: {
        fill_style: "white",
        font: "24px \"Arial Black\", Arial",
      },
      center: "0.5,0.5",
      pos: "397, 225",
    },
    {
      id: "score_board",
      template: "ui/score_board.ui.json5",
      visible: false,
    },
    {
      i18n: "demo_cam_ctrl",
      outlineColor: "#005A8E",
      outlineWidth: 1,
      outlineAlpha: 1,
      style: {
        fill_style: "white",
        font: "9px Arial",
      },
      component: [ { name: "Alignment", properties: { right: "right", bottom: "bottom" } } ],
      center: "1,1",
    },
    {
      id: "curr_focus_prefix",
      i18n: "curr_focus",
      outlineColor: "#005A8E",
      outlineWidth: 1,
      outlineAlpha: 1,
      style: {
        fill_style: "white",
        font: "9px Arial",
      },
      component: [
        {
          id: "focus_prefix",
          name: "Label",
        },
        { name: "Alignment", properties: { left: "left", bottom: "bottom" } },
      ],
      center: "0,1",
    },
    {
      id: "curr_focus",
      i18n: "",
      outlineColor: "#005A8E",
      outlineWidth: 1,
      outlineAlpha: 1,
      style: {
        fill_style: "white",
        font: "9px Arial",
      },
      component: [
        {
          id: "focus_on",
          name: "Label",
        },
        {
          name: "Alignment",
          properties: { left: "right", bottom: "bottom", followed: { l: "id:curr_focus_prefix" } },
        },
      ],
      center: "0,1",
    },
  ],
  actions: {
    stop: [ "remove_all_entities()", "destory_stage()" ],
  },
}
