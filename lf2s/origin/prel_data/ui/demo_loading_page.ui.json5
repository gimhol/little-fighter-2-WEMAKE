        h: 80,
      },
      center: "0, 0",
      pos: "10,10",
      opacity: 0.3,
    },
    {
      id: "txt_loading_content",
      component: [ "LoadingContentText(demo_mode_page)" ],
      pos: "10,420",
      center: "0,0",
      i18n: "",
      style: {
        font: "16px Arial",
        disposable: true,
      },
    },
    {
      id: "stage_transition",
      component: [ "StageTransitions()" ],
    },
    {
      id: "demo_play_link",
      i18n: "Click here to visit & play it.  ( https://lf.gim.ink )",
