      outlineAlpha: 1,
      style: {
        underline_color: "white",
        underline_width: 1,
        font: "9px Arial",
      },
      center: "0.5, 0",
      pos: "400, 0",
      actions: {
        click: [ "sound(ok)", "link_to(https://lf.gim.ink)" ],
      },
    },
    "builtin_data/launch/version_name.ui.json5",
