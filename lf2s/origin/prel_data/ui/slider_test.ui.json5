                },
              ],
            },
          ],
        },
      ],
    },
    toggle_row: {
      size: "700,36",
      center: "0.5,0.5",
      color: "red",
      component: [
        {
          name: "Flex",
          properties: { direction: "row", align: "center" },
        },
